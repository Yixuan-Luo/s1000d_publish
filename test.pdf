    </chapter><chapter xml:id="ID_S1KDTOOLS-A-00-00-00-00A-014A-D"><info><title>s1kd-tools</title><subtitle>.defaults file identifiers</subtitle><date>2020-09-01</date><bibliomisc role="publication.title">s1kd-tools</bibliomisc><bibliomisc role="publication.author">khzae.net</bibliomisc><bibliomisc role="page.header.logo">
