      </bibliomisc><bibliomisc role="producedby.blurb">Produced by: khzae.net</bibliomisc><bibliomisc role="data.module.code">S1KDTOOLS-A-41-00-00-00A-040A-D</bibliomisc><bibliomisc role="publication.code">S1KDTOOLS-KHZAE-00000-00</bibliomisc><bibliomisc role="classification">UNCLASSIFIED</bibliomisc><bibliomisc role="applicability">Version: 3.3.0</bibliomisc></info><bridgehead renderas="centerhead">References</bridgehead><table pgwide="1" frame="topbot" colsep="0" role="refs"><title>References</title><tgroup cols="2" align="left"><thead><row><entry>Data module/Technical publication</entry><entry>Title</entry></row></thead><tbody rowsep="0"><row><entry>None</entry><entry/></row></tbody></tgroup></table><bridgehead renderas="centerhead">Description</bridgehead>
      <para>This is a placeholder for the description content.</para>
    </chapter><chapter xml:id="ID_S1KDTOOLS-A-41-10-00-00A-040A-D"><info><title>娛樂系統</title><subtitle>Description</subtitle><date>2025-11-23</date><bibliomisc role="publication.title">s1kd-tools</bibliomisc><bibliomisc role="publication.author">khzae.net</bibliomisc><bibliomisc role="page.header.logo">
        <inlinemediaobject><imageobject xmlns:ier="InfoEntityResolver"><imagedata align="center" fileref="custom/ICN-S1KDTOOLS-A-000000-A-KHZAE-00001-A-001-01.PNG" depth="12mm" contentdepth="12mm"/></imageobject></inlinemediaobject>
      </bibliomisc><bibliomisc role="producedby.blurb">Produced by: khzae.net</bibliomisc><bibliomisc role="data.module.code">S1KDTOOLS-A-41-10-00-00A-040A-D</bibliomisc><bibliomisc role="publication.code">S1KDTOOLS-KHZAE-00000-00</bibliomisc><bibliomisc role="classification">UNCLASSIFIED</bibliomisc><bibliomisc role="applicability">Version: 3.3.0</bibliomisc></info><bridgehead renderas="centerhead">References</bridgehead><table pgwide="1" frame="topbot" colsep="0" role="refs"><title>References</title><tgroup cols="2" align="left"><thead><row><entry>Data module/Technical publication</entry><entry>Title</entry></row></thead><tbody rowsep="0"><row><entry>None</entry><entry/></row></tbody></tgroup></table><bridgehead renderas="centerhead">Description</bridgehead>
      <para>This is a placeholder for the description content.</para>
            <table id="ID_S1KDTOOLS-A-41-10-00-00A-040A-D-tab-20251128145247" frame="topbot">
          <title>物理特性_J</title>
          <tgroup cols="2">
            <colspec colname="col1" colwidth="1*"/>
            <colspec colname="col2" colwidth="10*"/>
            <thead>
              <row rowsep="1">
                <entry>
                  <para>項目</para>
                </entry>
                <entry>
                  <para>數值／說明</para>
                </entry>
              </row>
            </thead>
            <tbody>
              <row>
                <entry>
                  <para>顏色</para>
                </entry>
                <entry>
                  <para>紅、棕</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>比重</para>
                </entry>
                <entry>
                  <para>1.40 ± 0.03 g/cm³</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>去黏硬化時間</para>
                </entry>
                <entry>
                  <para>0.5–1 小時（視溫度與空氣濕度而定）</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>使用溫度</para>
                </entry>
                <entry>
                  <para>-50°C 至 +180°C</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>抗拉強度</para>
                </entry>
                <entry>
                  <para>1.5 MPa</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>斷裂伸長率</para>
                </entry>
                <entry>
                  <para>200%</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>硬度</para>
                </entry>
                <entry>
                  <para>邵氏硬度 45 度 A</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>彈性恢復</para>
                </entry>
                <entry>
                  <para>大約 50%</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>抗化性</para>
                </entry>
                <entry>
                  <para>抗紫外線、臭氧、極地條件</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>老化</para>
                </entry>
                <entry>
                  <para>20 年後</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>罐裝規格</para>
                </entry>
                <entry>
                  <para>310 ml 硬罐</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>儲藏方式</para>
                </entry>
                <entry>
                  <para>置於乾燥陰涼處，最低/最高溫 +5°C / +30°C</para>
                </entry>
              </row>
              <row>
                <entry>
                  <para>儲藏期限</para>
                </entry>
                <entry>
                  <para>製造日期後 6 個月；若於製造日期 6 個月後使用，必須檢查硬化與黏著性能</para>
                </entry>
              </row>
            </tbody>
          </tgroup>
        </table>
    </chapter><chapter xml:id="ID_S1KDTOOLS-A-41-20-00-00A-040A-D"><info><title>警報、安全及警示系統</title><subtitle>Description</subtitle><date>2025-11-23</date><bibliomisc role="publication.title">s1kd-tools</bibliomisc><bibliomisc role="publication.author">khzae.net</bibliomisc><bibliomisc role="page.header.logo">
