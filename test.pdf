learnCode                      H10
learnEventCode                 A
maintainedSns                  General sea vehicles
modelIdentCode                 MYPRJ
omitIssueInfo                  true
originatorCode                 12345
originator                     khzae.net
pmIssuer                       12345
pmNumber                       00000
pmVolume                       00
receiver                       khzae.net
